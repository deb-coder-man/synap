# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Direct Neon endpoint — used by the Neon serverless adapter at runtime.
# Do NOT add pgbouncer=true; the serverless adapter manages its own connections.
# Find in Neon dashboard → Connection Details → Direct connection
DATABASE_URL="postgresql://[user]:[password]@[endpoint].[region].aws.neon.tech/neondb?sslmode=require"

# Same direct endpoint — used by Prisma migrate.
DIRECT_URL="postgresql://[user]:[password]@[endpoint].[region].aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Email / Magic Link (SMTP) ────────────────────────────────────────────────
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="Synap <noreply@example.com>"
