// Learn more about Prisma schema: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Required Models ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Only set for credentials (email/password) accounts
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  // App relations
  boards        Board[]
  archivedCards ArchivedCard[]
  settings      UserSettings?
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── App Models ───────────────────────────────────────────────────────────────

model Board {
  id          String   @id @default(cuid())
  name        String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  lists List[]
}

model List {
  id        String   @id @default(cuid())
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cards Card[]
}

model Card {
  id               String    @id @default(cuid())
  title            String
  description      String?
  order            Int       @default(0)
  // Eisenhower matrix axes
  urgent           Boolean   @default(false)
  important        Boolean   @default(false)
  // Action page fields
  estimatedHours   Float?
  requiresDeepWork Boolean   @default(false)
  // Scheduling
  dueDate          DateTime?
  // Completion
  completed        Boolean   @default(false)
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  listId String
  list   List   @relation(fields: [listId], references: [id], onDelete: Cascade)
}

model ArchivedCard {
  id                String    @id @default(cuid())
  title             String
  description       String?
  urgent            Boolean
  important         Boolean
  estimatedHours    Float?
  requiresDeepWork  Boolean
  dueDate           DateTime?
  completedAt       DateTime?
  archivedAt        DateTime  @default(now())
  originalListName  String
  originalBoardName String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── User Settings (Customisation) ────────────────────────────────────────────

model UserSettings {
  id              String   @id @default(cuid())
  backgroundColor String   @default("#ffffff")
  textColor       String   @default("#111111")
  fontFamily      String   @default("Inter")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId String       @unique
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}
